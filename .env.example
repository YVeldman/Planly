# Pooled connection (used by the app at runtime). With Supabase this is the
# "Transaction pooler" string (port 6543, includes ?pgbouncer=true).
DATABASE_URL="postgresql://user:password@host:5432/planly?sslmode=require"
# Direct (non-pooled) connection, only used to run migrations. With Supabase
# this is the "Session pooler" or direct connection string (port 5432).
DIRECT_URL="postgresql://user:password@host:5432/planly?sslmode=require"
AUTH_SECRET="replace-with-a-long-random-string"

# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="replace-with-vapid-public-key"
VAPID_PRIVATE_KEY="replace-with-vapid-private-key"
VAPID_SUBJECT="mailto:you@example.com"

# Resend (https://resend.com) — used to send account verification emails
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="Planly <onboarding@resend.dev>"

# Public URL of the app, used to build links in emails
NEXT_PUBLIC_APP_URL="http://localhost:3000"
