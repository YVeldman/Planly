// Prisma schema for Planly - the family planner app

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Family {
  id             String   @id @default(cuid())
  name           String
  inviteCode     String   @unique @default(cuid())
  icsToken       String   @unique @default(cuid())
  plan           String   @default("free") // free | premium
  rewardsEnabled Boolean  @default(false)
  createdAt      DateTime @default(now())

  members       User[]
  events        Event[]
  tasks         Task[]
  contacts      Contact[]
  externalFeeds ExternalCalendarFeed[]
  meals         Meal[]
  rewardItems   RewardItem[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  passwordHash String?
  color        String   @default("#7C9473")
  role         String   @default("member") // owner | member
  isChild      Boolean  @default(false)
  createdAt    DateTime @default(now())

  // Recurring allowance: parents can grant a child a fixed number of
  // points per week. Accrual is computed lazily (see lib/allowance.ts)
  // rather than via a scheduled job.
  allowancePointsPerWeek Int?
  allowanceStartDate     DateTime?
  allowanceLastAccruedAt DateTime?

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  events Event[] @relation("EventAssignee")
  tasks  Task[]  @relation("TaskAssignee")

  pushSubscriptions PushSubscription[]
  pointTransactions PointTransaction[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id        String    @id @default(cuid())
  title     String
  category  String    @default("other") // school | work | health | family | sport | meal | other
  startTime DateTime
  endTime   DateTime?
  location  String?
  notes     String?
  createdAt DateTime  @default(now())

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("EventAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  source         String                @default("planly") // planly | external
  externalUid    String?
  externalFeedId String?
  externalFeed   ExternalCalendarFeed? @relation(fields: [externalFeedId], references: [id], onDelete: Cascade)

  @@unique([externalFeedId, externalUid])
}

model ExternalCalendarFeed {
  id           String    @id @default(cuid())
  name         String
  url          String
  lastSyncedAt DateTime?
  lastError    String?
  createdAt    DateTime  @default(now())

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  events Event[]
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  role      String? // e.g. huisarts, school, oppas
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model Task {
  id        String    @id @default(cuid())
  title     String
  done      Boolean   @default(false)
  dueDate   DateTime?
  category  String    @default("other")
  createdAt DateTime  @default(now())

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
}

model Meal {
  id        String   @id @default(cuid())
  title     String
  date      DateTime
  prepTime  Int? // minutes
  notes     String?
  favorite  Boolean  @default(false)
  createdAt DateTime @default(now())

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model RewardItem {
  id        String   @id @default(cuid())
  name      String
  pointCost Int
  emoji     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model PointTransaction {
  id        String   @id @default(cuid())
  amount    Int // positive = earned/awarded, negative = spent
  reason    String
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
